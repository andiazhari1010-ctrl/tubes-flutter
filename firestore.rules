rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper function to check if the user is accessing their own document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Helper function to check if the requestor is an admin
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      // Allow reading if the user is signed in (needed for leaderboard and party views)
      allow read: if isSignedIn();
      
      // Allow creating if the user is the owner and registers as a standard 'user', or if their email contains 'admin'/'tubaguslinggaap', or if the requestor is an admin
      allow create: if (isOwner(userId) && 
        (request.resource.data.role == 'user' || 
         ('email' in request.resource.data && (
           request.resource.data.email.lower().matches('.*admin.*') || 
           request.resource.data.email.lower().matches('.*tubaguslinggaap.*')
         )))) || isAdmin();
      
      // Allow updating if:
      // 1. The user is the owner, and they don't change their role, or their email contains 'admin'/'tubaguslinggaap'
      // 2. The requestor is an admin
      allow update: if (isOwner(userId) && 
        (request.resource.data.role == resource.data.role || 
         ('email' in request.resource.data && (
           request.resource.data.email.lower().matches('.*admin.*') || 
           request.resource.data.email.lower().matches('.*tubaguslinggaap.*')
         )))) || isAdmin();
      
      // Allow deleting if the requestor is an admin
      allow delete: if isAdmin();
    }

    match /parties/{partyId} {
      allow read, write: if isSignedIn();
    }

    match /global_quests/{questId} {
      allow read, write: if isSignedIn();
    }

    match /global_bosses/{bossId} {
      allow read, write: if isSignedIn();
    }

    match /shop_items/{itemId} {
      allow read, write: if isSignedIn();
    }
  }
}
