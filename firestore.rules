rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Apakah user sudah login.
    function isSignedIn() {
      return request.auth != null;
    }

    // Apakah requestor adalah pemilik dokumen (uid sama).
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Apakah requestor adalah admin (cek field role di dokumen users miliknya).
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Anti-tamper sederhana: stat hero yang seharusnya terbatas tidak boleh
    // diisi nilai ngawur (HP 0-150, MP 0-100, Momentum 0-100, Level >= 1).
    // Gold/XP/Gems tidak dibatasi karena memang tumbuh; pencegahan penuh
    // membutuhkan validasi sisi server (Cloud Functions).
    function validHeroStats() {
      return request.resource.data.hero.level >= 1 &&
        request.resource.data.hero.hp >= 0 &&
        request.resource.data.hero.hp <= 150 &&
        request.resource.data.hero.mp >= 0 &&
        request.resource.data.hero.mp <= 100 &&
        request.resource.data.hero.momentum >= 0 &&
        request.resource.data.hero.momentum <= 100;
    }

    // ── Helper validasi update party (operasi self-only, bukan "siapa saja") ──

    // Hanya key di [keys] yang berubah antara dokumen lama & baru.
    function partyAffectedOnly(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    // Anggota keluar: hanya memberIds berubah, dan user hanya menghapus DIRINYA
    // (ada di list lama, hilang di list baru, tidak ada anggota lain disentuh).
    function partyLeavingSelf() {
      return partyAffectedOnly(['memberIds']) &&
        (request.auth.uid in resource.data.memberIds) &&
        !(request.auth.uid in request.resource.data.memberIds) &&
        request.resource.data.memberIds.hasOnly(resource.data.memberIds);
    }

    // Menerima undangan: user yang diundang menambah DIRINYA ke memberIds dan
    // mencabut dirinya dari invitedIds; anggota lain tidak diutak-atik.
    function partyAcceptSelf() {
      return partyAffectedOnly(['memberIds', 'invitedIds']) &&
        (request.auth.uid in resource.data.invitedIds) &&
        (request.auth.uid in request.resource.data.memberIds) &&
        !(request.auth.uid in request.resource.data.invitedIds) &&
        request.resource.data.memberIds.hasOnly(resource.data.memberIds.concat([request.auth.uid])) &&
        resource.data.memberIds.hasOnly(request.resource.data.memberIds) &&
        request.resource.data.invitedIds.hasOnly(resource.data.invitedIds);
    }

    // Menolak undangan: hanya menghapus DIRINYA dari invitedIds.
    function partyDeclineSelf() {
      return partyAffectedOnly(['invitedIds']) &&
        (request.auth.uid in resource.data.invitedIds) &&
        !(request.auth.uid in request.resource.data.invitedIds) &&
        request.resource.data.invitedIds.hasOnly(resource.data.invitedIds);
    }

    match /users/{userId} {
      // Dokumen user memuat data privat (email, telepon, task). Hanya boleh
      // dibaca pemilik & admin. Pengecualian: user lain boleh menemukan
      // dokumen "placeholder" yang dibuat admin dengan email mereka sendiri
      // (untuk klaim akun saat pertama mendaftar) — tetap aman karena hanya
      // cocok pada email milik si peminta sendiri.
      allow read: if isOwner(userId) || isAdmin() ||
        (isSignedIn() && resource.data.email == request.auth.token.email);

      // Buat dokumen: pemilik mendaftar sebagai 'user' biasa, atau admin.
      // Promosi ke admin hanya lewat admin lain / Firebase Console.
      allow create: if isAdmin() ||
        (isOwner(userId) && request.resource.data.role == 'user');

      // Update: admin bebas; pemilik hanya boleh mengubah datanya sendiri
      // tanpa menaikkan role dan dengan stat hero tetap dalam batas wajar.
      allow update: if isAdmin() ||
        (isOwner(userId) &&
         request.resource.data.role == resource.data.role &&
         validHeroStats());

      // Hapus: hanya admin.
      allow delete: if isAdmin();
    }

    // Profil publik: hanya nama + stat hero untuk leaderboard & party. Tidak
    // memuat email/telepon, jadi aman dibaca semua user login. Ditulis oleh
    // pemilik (cermin profilnya sendiri) atau admin (sinkron saat edit/hapus).
    match /public_profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /parties/{partyId} {
      allow read: if isSignedIn();

      // Pembuat party harus mendaftarkan dirinya sebagai leader sekaligus
      // anggota pertama satu-satunya (tidak menambahkan orang lain diam-diam).
      allow create: if isSignedIn() &&
        request.resource.data.leaderId == request.auth.uid &&
        request.resource.data.memberIds == [request.auth.uid];

      // Update kini self-only, bukan lagi "user mana pun boleh mengubah party
      // mana pun". Diizinkan untuk: leader (kontrol penuh atas party-nya),
      // anggota yang keluar sendiri, penerima undangan, dan penolak undangan.
      allow update: if isSignedIn() && (
        resource.data.leaderId == request.auth.uid ||
        partyLeavingSelf() ||
        partyAcceptSelf() ||
        partyDeclineSelf()
      );

      // Hanya leader yang boleh membubarkan party.
      allow delete: if isSignedIn() && resource.data.leaderId == request.auth.uid;
    }

    match /global_quests/{questId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /global_bosses/{bossId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      // Admin boleh edit penuh; user biasa hanya boleh mengubah field 'progress'
      // (dipakai fitur serang boss).
      allow update: if isAdmin() ||
        (isSignedIn() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['progress']));
    }

    match /shop_items/{itemId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Laporan dari user ke admin. User boleh MEMBUAT laporan atas namanya
    // sendiri; hanya admin yang boleh membaca & menindaklanjuti (review/hapus).
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Pengumuman/broadcast admin. Semua user login boleh membaca (untuk tampil
    // sebagai notifikasi); hanya admin yang boleh menulis.
    match /broadcasts/{broadcastId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
